generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Shop {
  id            String   @id @default(uuid())
  name          String
  phone         String?
  email         String?
  address       String?
  logoUrl       String?
  niche         String   @default("barbearia")
  bookingBuffer Int      @default(0) // minutos de antecedência mínima para agendamento
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  users         User[]
  services      Service[]
  professionals Professional[]
  clients       Client[]
  units         Unit[]
  appointments  Appointment[]
  shopHours     ShopHour[]
  timeBlocks    TimeBlock[]
}

model User {
  id             String    @id @default(uuid())
  shopId         String
  name           String
  email          String    @unique
  passwordHash   String
  role           Role      @default(leader)
  professionalId String?   @unique
  referralId     String?
  resetToken     String?
  resetTokenExp  DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  shop         Shop          @relation(fields: [shopId], references: [id])
  professional Professional? @relation(fields: [professionalId], references: [id])
  userPlan     UserPlan?
  referral     Referral?     @relation(fields: [referralId], references: [id])
}

enum Role {
  admin
  leader
  professional
}

model ShopHour {
  id     String  @id @default(uuid())
  shopId String
  day    String
  start  String?
  end    String?

  shop Shop @relation(fields: [shopId], references: [id])

  @@unique([shopId, day])
}

model Service {
  id          String      @id @default(uuid())
  shopId      String
  name        String
  duration    Int
  price       Int
  description String?
  icon        String?
  image       String?
  type        ServiceType @default(service)
  active      Boolean     @default(true)
  deletedAt   DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  shop                 Shop                  @relation(fields: [shopId], references: [id])
  appointments         Appointment[]
  professionalServices ProfessionalService[]

  @@index([shopId])
}

enum ServiceType {
  service
  addon
}

model Professional {
  id          String    @id @default(uuid())
  shopId      String
  unitId      String?
  name        String
  avatar      String?
  specialties String[]
  phone       String?
  email       String?
  active      Boolean   @default(true)
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  shop                 Shop                  @relation(fields: [shopId], references: [id])
  unit                 Unit?                 @relation(fields: [unitId], references: [id])
  workingHours         WorkingHour[]
  appointments         Appointment[]
  timeBlocks           TimeBlock[]
  user                 User?
  professionalUnits    ProfessionalUnit[]
  professionalServices ProfessionalService[]

  @@index([shopId])
}

model WorkingHour {
  id             String  @id @default(uuid())
  professionalId String
  day            String
  start          String?
  end            String?
  lunchStart     String?
  lunchEnd       String?

  professional Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  @@unique([professionalId, day])
}

model Client {
  id         String    @id @default(uuid())
  shopId     String
  name       String?
  phone      String
  email      String?
  notes      String?
  birthday   String?
  totalSpent Int       @default(0)
  lastVisit  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  shop         Shop          @relation(fields: [shopId], references: [id])
  appointments Appointment[]

  @@unique([shopId, phone])
}

model Appointment {
  id             String            @id @default(uuid())
  shopId         String
  unitId         String?
  clientId       String
  serviceId      String
  professionalId String
  date           String
  time           String
  duration       Int
  price          Int
  status         AppointmentStatus @default(confirmed)
  cancelReason   String?
  notes          String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  shop         Shop                @relation(fields: [shopId], references: [id])
  unit         Unit?               @relation(fields: [unitId], references: [id])
  client       Client              @relation(fields: [clientId], references: [id])
  service      Service             @relation(fields: [serviceId], references: [id])
  professional Professional        @relation(fields: [professionalId], references: [id])
  addons       AppointmentAddon[]

  @@index([shopId, date])
  @@index([professionalId, date])
  @@index([clientId])
}

model AppointmentAddon {
  id            String @id @default(uuid())
  appointmentId String
  serviceId     String
  name          String
  duration      Int
  price         Int

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
}

enum AppointmentStatus {
  confirmed
  cancelled
  completed
}

model Unit {
  id         String   @id @default(uuid())
  shopId     String
  name       String
  slug       String   @unique
  phone      String?
  zipcode    String?
  street     String?
  number     String?
  complement String?
  district   String?
  city       String?
  state      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  shop              Shop               @relation(fields: [shopId], references: [id])
  professionals     Professional[]
  professionalUnits ProfessionalUnit[]
  appointments      Appointment[]
}

model ProfessionalUnit {
  id             String   @id @default(uuid())
  professionalId String
  unitId         String
  createdAt      DateTime @default(now())

  professional Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  unit         Unit         @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@unique([professionalId, unitId])
}

model ProfessionalService {
  id             String   @id @default(uuid())
  professionalId String
  serviceId      String
  createdAt      DateTime @default(now())

  professional Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  service      Service      @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([professionalId, serviceId])
}

model TimeBlock {
  id                String   @id @default(uuid())
  shopId            String
  professionalId    String
  date              String
  startTime         String
  duration          Int
  reason            String?
  recurrenceGroupId String?
  recurrenceDays    String[]
  recurrenceEndDate String?
  createdAt         DateTime @default(now())

  shop         Shop         @relation(fields: [shopId], references: [id], onDelete: Cascade)
  professional Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  @@index([shopId, date])
  @@index([professionalId, date])
  @@index([recurrenceGroupId])
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  CONFIRMED
  INACTIVE
}

model Plan {
  id                String   @id // "FREE" | "PREMIUM" | "PRO" | "ADMIN"
  name              String
  price             Int
  packagePrice      Int      @default(0)
  unitLimit         Int      // -1 = ilimitado
  professionalLimit Int      // -1 = ilimitado
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  userPlans UserPlan[]
}

model UserPlan {
  id                 String             @id @default(uuid())
  userId             String             @unique
  planId             String
  subscriptionId     String?
  subscriptionStatus SubscriptionStatus @default(TRIAL)
  isPackage          Boolean            @default(false)
  packageExpiresAt   DateTime?
  planExpiresAt      DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id])
  plan Plan @relation(fields: [planId], references: [id])
}

model Referral {
  id              String   @id @default(uuid())
  code            String   @unique
  name            String?
  email           String?
  commissionType  String   // "percentage" | "fixed"
  commissionValue Int      // centavos para fixed, inteiro para percentage
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  users User[]
}
